# ============================================
# MyCaseValue Environment Variables
# Copy this to .env.local and fill in values
# ============================================

# ── SUPABASE (Database) ──────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── DATA SOURCES ─────────────────────────────
# CourtListener API (free, get token at https://www.courtlistener.com/sign-in/)
COURTLISTENER_API_TOKEN=your-courtlistener-token

# ── GOOGLE ──────────────────────────────────
# GA4 Measurement ID (find in GA4 property settings)
# If not set, GA4 will be disabled (graceful no-op)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G_XXXXXXXXXX

# Google Site Verification (meta tag for Google Search Console)
# PUBLIC - used in HTML meta tags
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your-google-site-verification-code

# ── INGESTION SECURITY ──────────────────────
# Random key to protect the /api/ingest endpoint
INGEST_API_KEY=generate-a-random-key-here

# Vercel cron secret (auto-set by Vercel for cron jobs)
CRON_SECRET=your-cron-secret

# ISR/Revalidation secret for on-demand revalidation
# SERVER-ONLY - used in API routes to trigger cache revalidation
REVALIDATION_SECRET=generate-a-random-key-here

# ── PUSH NOTIFICATIONS ──────────────────────
# Web Push API credentials (VAPID keys)
# Generate at: https://vapidkeys.com/ or use `npm install -g web-push` && `web-push generate-vapid-keys`
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:your-email@example.com

# API key to protect push send endpoint
PUSH_API_KEY=generate-a-random-key-here
