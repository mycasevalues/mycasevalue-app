# ============================================
# MyCaseValue Environment Variables
# Copy this to .env.local and fill in values
# ============================================

# ============================================
# SUPABASE (Database & Authentication)
# ============================================
# Get these from your Supabase project settings (Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key - keep this secret! Only used server-side
# Get from Supabase Settings > API > Service role secret
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================
# SENTRY (Error Tracking)
# ============================================
# Get these from your Sentry project settings
# Visit: https://sentry.io/settings/[org]/projects/[project]/keys/dsn/
NEXT_PUBLIC_SENTRY_DSN=https://[key]@o[org].ingest.sentry.io/[project]

# Sentry auth token for build-time setup (if needed)
# Get from: https://sentry.io/settings/account/tokens/
SENTRY_AUTH_TOKEN=sntrys_eyJ...

# Sentry organization slug
SENTRY_ORG=your-org-slug

# Sentry project slug
SENTRY_PROJECT=your-project-slug

# ============================================
# UPSTASH REDIS (Caching & Rate Limiting)
# ============================================
# Get these from your Upstash console dashboard
# Visit: https://console.upstash.com/redis
UPSTASH_REDIS_REST_URL=https://[name]-[hash].upstash.io

UPSTASH_REDIS_REST_TOKEN=AX...

# ============================================
# RESEND (Email Service)
# ============================================
# Get from: https://resend.com/api-keys
# Used for sending emails (newsletters, notifications, reports)
RESEND_API_KEY=re_...

# ============================================
# SITE CONFIGURATION
# ============================================
# Your application's public URL (used in email links, redirects, etc.)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ============================================
# OPTIONAL: Additional Integrations
# ============================================

# Anthropic API Key (if using Claude AI features)
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# CourtListener API Token (if integrating court data)
# Get from: https://www.courtlistener.com/api/
COURTLISTENER_API_TOKEN=your_courtlistener_token

# BLS API Key (if using labor statistics)
# Get from: https://www.bls.gov/developers/home.htm
BLS_API_KEY=your_bls_key

# ISR Revalidation Secret (for next/revalidate)
# Generate a random 32-character string for security
REVALIDATION_SECRET=your_32_char_random_string_here_1234

# Admin Data Quality Token (for internal tools)
# Generate a strong random string
ADMIN_DATA_QUALITY_TOKEN=your_admin_token_here
