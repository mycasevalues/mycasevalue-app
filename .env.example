# ============================================
# MyCaseValue Environment Variables
# Copy this to .env.local and fill in values
# ============================================

# ── SUPABASE (Database) ──────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── DATA SOURCES ─────────────────────────────
# CourtListener API (free, get token at https://www.courtlistener.com/sign-in/)
COURTLISTENER_API_TOKEN=your-courtlistener-token

# ── STRIPE (Payments) ───────────────────────
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_BASE_URL=https://mycasevalues.com

# ── GOOGLE ANALYTICS 4 ───────────────────────
# GA4 Measurement ID (find in GA4 property settings)
# If not set, GA4 will be disabled (graceful no-op)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G_XXXXXXXXXX

# ── INGESTION SECURITY ──────────────────────
# Random key to protect the /api/ingest endpoint
INGEST_API_KEY=generate-a-random-key-here

# Vercel cron secret (auto-set by Vercel for cron jobs)
CRON_SECRET=your-cron-secret
